{
  "name": "eventaj-galerija",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:retention": "wrangler deploy --config wrangler.retention.jsonc",
    "r2:cors:apply": "wrangler r2 bucket cors set eventaj-galerija-media --file config/r2-cors.json --jurisdiction eu --force",
    "r2:cors:list": "wrangler r2 bucket cors list eventaj-galerija-media --jurisdiction eu",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply eventaj-galerija --local",
    "db:migrate:remote": "wrangler d1 migrations apply eventaj-galerija --remote",
    "auth:hash": "node scripts/hash-admin-password.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "next": "latest",
    "next-auth": "5.0.0-beta.31",
    "qrcode": "1.5.4",
    "react": "latest",
    "react-dom": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "latest",
    "@types/qrcode": "^1.5.6",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "^9.39.0",
    "eslint-config-next": "latest",
    "typescript": "^6.0.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  },
  "packageManager": "pnpm@8.15.8"
}
